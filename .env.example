# =============================================================
# .env.example - Vorlage fuer lokale Umgebungsvariablen
# =============================================================
#
# Diese Datei dient NUR als Vorlage und enthaelt keine echten Secrets.
# Sie wird ins Git-Repository eingecheckt, damit jede:r weiss,
# welche Variablen die Anwendung erwartet.
#
# So wird die Datei sicher benutzt:
#
# 1. Kopiere diese Datei in eine neue Datei mit dem Namen `.env`:
#
#       cp .env.example .env
#
# 2. Trage in `.env` deinen echten OpenAI API Key ein
#    (anstelle von `replace-me`).
#
# 3. Pruefe, dass `.env` in `.gitignore` steht (ist bereits gesetzt),
#    damit der Key NIE in das Repository hochgeladen wird.
#
# 4. Starte die Anwendung anschliessend mit:
#
#       docker compose up -d
#
#    Docker Compose liest die Variablen aus `.env` automatisch ein
#    und reicht sie an den AI Service weiter.
#
# 5. Fuer Kubernetes wird der Key NICHT aus `.env` gelesen,
#    sondern ueber `k8s/ai-api-sealed-secret.yml` bereitgestellt.
#
# Wichtig:
# - Niemals echte Keys in `.env.example`, README oder Code schreiben.
# - Den Key nicht in Slack, Chats oder Issues teilen.
# - Bei Verdacht auf Leak: Key sofort im OpenAI-Dashboard widerrufen
#   und einen neuen erzeugen.
# =============================================================

OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4o-mini
